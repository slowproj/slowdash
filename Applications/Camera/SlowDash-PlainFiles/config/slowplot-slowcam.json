{
    "control": {
        "range": { "length": 300, "to": 0 },
        "reload": 10,
        "mode": "normal",
        "grid": { "rows": 2, "columns": 2 }
    },
    "style": { },
    "panels": [
        { "type": "blob", "channel": "Photo" },
        {
            "type": "timeseries",
            "plots": [
                {
                    "type": "timeseries",
                    "channel": "Brightness",
                    "color": "#009090",
                    "label": "",
                    "format": "%.5g",
                    "opacity": 1,
                    "marker_type": "circle",
                    "marker_size": 2,
                    "line_width": 1,
                    "line_type": "connect",
                    "fill_opacity": 0,
                    "fill_envelope": false,
                    "fill_baseline": 1e-100,
                    "resampling": { "buckets": null, "threshold": null, "reducer": "last", "envelope": false }
                }
            ],
            "axes": { "xfixed": false, "yfixed": false, "xlog": false, "ylog": false, "zlog": false, "ymin": 30, "ymax": 60 },
            "legend": { "style": "transparent", "position": "left" }
        },
        { "type": "tree", "channel": "Properties" }
    ],
    "meta": { "name": "slowcam", "title": "", "description": "" }
}
